---
// Tensile test machine with "LLM" sample being tested
---
<svg viewBox="0 0 700 480" fill="none" xmlns="http://www.w3.org/2000/svg" class="illustration" role="img" aria-label="A tensile test machine stretching a sample labeled LLM, revealing material properties">
  <!-- Machine frame - hand-drawn wobbly -->
  <path d="M120 60 C122 57, 478 56, 480 60 L483 420 C482 423, 119 422, 118 420 Z" stroke="var(--ink)" stroke-width="3" fill="none" stroke-linecap="round"/>

  <!-- Base -->
  <path d="M90 420 C92 417, 510 416, 512 420 L516 450 C515 453, 87 452, 86 450 Z" stroke="var(--ink)" stroke-width="3" fill="var(--paper-dark)" stroke-linecap="round"/>

  <!-- Top clamp -->
  <path d="M240 105 L360 105 L360 142 L240 142 Z" stroke="var(--ink)" stroke-width="3" fill="var(--ink-faint)" stroke-linecap="round" opacity="0.3"/>
  <path d="M243 108 L357 107 L358 140 L242 142 Z" stroke="var(--ink)" stroke-width="2.5" fill="none" stroke-linecap="round"/>
  <circle cx="255" cy="123" r="6" stroke="var(--ink)" stroke-width="2" fill="var(--paper)"/>
  <circle cx="345" cy="123" r="6" stroke="var(--ink)" stroke-width="2" fill="var(--paper)"/>

  <!-- Bottom clamp -->
  <path d="M240 308 L360 308 L360 345 L240 345 Z" stroke="var(--ink)" stroke-width="3" fill="var(--ink-faint)" stroke-linecap="round" opacity="0.3"/>
  <path d="M242 310 L358 308 L360 343 L240 345 Z" stroke="var(--ink)" stroke-width="2.5" fill="none" stroke-linecap="round"/>
  <circle cx="255" cy="327" r="6" stroke="var(--ink)" stroke-width="2" fill="var(--paper)"/>
  <circle cx="345" cy="327" r="6" stroke="var(--ink)" stroke-width="2" fill="var(--paper)"/>

  <!-- The LLM sample - stretched, showing stress -->
  <path d="M278 142 C275 165, 268 195, 264 225 C260 255, 270 285, 278 308" stroke="var(--red-pencil)" stroke-width="4" fill="none" stroke-linecap="round"/>
  <path d="M322 142 C325 165, 332 195, 336 225 C340 255, 330 285, 322 308" stroke="var(--red-pencil)" stroke-width="4" fill="none" stroke-linecap="round"/>
  <!-- necking in the middle -->
  <path d="M264 225 C270 222, 330 222, 336 225" stroke="var(--red-pencil)" stroke-width="2" fill="none" stroke-dasharray="5 4"/>

  <!-- LLM label on sample -->
  <text x="300" y="236" text-anchor="middle" font-family="Caveat, cursive" font-size="48" font-weight="700" fill="var(--red-pencil)">LLM</text>

  <!-- Stress arrows -->
  <path d="M300 82 L300 105" stroke="var(--blue-pencil)" stroke-width="2.5" marker-end="url(#arrowBlue)"/>
  <path d="M300 368 L300 345" stroke="var(--blue-pencil)" stroke-width="2.5" marker-end="url(#arrowBlue)"/>
  <text x="300" y="70" text-anchor="middle" font-family="Caveat, cursive" font-size="32" fill="var(--blue-pencil)">stress</text>
  <text x="300" y="395" text-anchor="middle" font-family="Caveat, cursive" font-size="32" fill="var(--blue-pencil)">stress</text>

  <!-- Properties callouts — text starts right of the machine frame -->
  <path d="M338 175 L486 152" stroke="var(--pencil)" stroke-width="1.5" stroke-dasharray="4 3"/>
  <text x="494" y="159" font-family="Caveat, cursive" font-size="28" fill="var(--pencil)">confidence inflation</text>

  <path d="M338 225 L486 220" stroke="var(--pencil)" stroke-width="1.5" stroke-dasharray="4 3"/>
  <text x="494" y="227" font-family="Caveat, cursive" font-size="28" fill="var(--pencil)">calibration gap</text>

  <path d="M338 275 L486 288" stroke="var(--pencil)" stroke-width="1.5" stroke-dasharray="4 3"/>
  <text x="494" y="295" font-family="Caveat, cursive" font-size="28" fill="var(--pencil)">plausible-but-wrong</text>

  <!-- Dial/gauge -->
  <circle cx="180" cy="240" r="45" stroke="var(--ink)" stroke-width="2.5" fill="var(--paper)"/>
  <path d="M180 240 L162 214" stroke="var(--red-pencil)" stroke-width="3" stroke-linecap="round"/>
  <circle cx="180" cy="240" r="4" fill="var(--ink)"/>
  <text x="180" y="302" text-anchor="middle" font-family="Caveat, cursive" font-size="28" fill="var(--pencil)">yield point?</text>

  <defs>
    <marker id="arrowBlue" markerWidth="10" markerHeight="7" refX="10" refY="3.5" orient="auto">
      <path d="M0 0 L10 3.5 L0 7" fill="none" stroke="var(--blue-pencil)" stroke-width="1.5"/>
    </marker>
  </defs>
</svg>
