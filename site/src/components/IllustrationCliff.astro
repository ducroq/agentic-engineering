---
// The auto-loading cliff - documents falling off the edge
---
<svg viewBox="0 0 400 320" fill="none" xmlns="http://www.w3.org/2000/svg" class="illustration" role="img" aria-label="Documents above and below a cliff edge. Above: agent sees them. Below: invisible.">
  <!-- Sky / above cliff -->
  <rect x="0" y="0" width="400" height="160" fill="none"/>

  <!-- Cliff surface -->
  <path d="M0 160 L220 160 L220 162 L225 170 L230 165 L240 180 L245 175 L250 190 L258 185 L260 200 L265 210 L270 230 L275 250 L280 280 L285 320" stroke="var(--ink)" stroke-width="3" fill="none" stroke-linecap="round"/>
  <!-- cliff top surface -->
  <path d="M0 160 L220 160" stroke="var(--ink)" stroke-width="3" stroke-linecap="round"/>
  <!-- cliff shading -->
  <path d="M225 170 L230 180 M235 178 L240 195 M245 185 L252 210 M255 200 L265 235 M268 225 L275 260" stroke="var(--ink-faint)" stroke-width="1" opacity="0.4"/>

  <!-- Ground texture on top -->
  <path d="M10 158 L30 157 M50 159 L75 157 M90 158 L120 157 M140 159 L160 157 M175 158 L210 157" stroke="var(--green-pencil)" stroke-width="1.5" opacity="0.3"/>

  <!-- Documents ABOVE the cliff (visible to agent) -->
  <!-- CLAUDE.md -->
  <g transform="translate(40, 90) rotate(-5)">
    <rect width="55" height="65" rx="2" fill="var(--paper)" stroke="var(--ink)" stroke-width="1.5"/>
    <line x1="8" y1="12" x2="47" y2="12" stroke="var(--ink-faint)" stroke-width="1"/>
    <line x1="8" y1="20" x2="42" y2="20" stroke="var(--ink-faint)" stroke-width="1"/>
    <line x1="8" y1="28" x2="45" y2="28" stroke="var(--ink-faint)" stroke-width="1"/>
    <line x1="8" y1="36" x2="38" y2="36" stroke="var(--ink-faint)" stroke-width="1"/>
    <text x="28" y="55" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="7" fill="var(--blue-pencil)">CLAUDE.md</text>
  </g>

  <!-- MEMORY.md -->
  <g transform="translate(120, 85) rotate(3)">
    <rect width="55" height="65" rx="2" fill="var(--paper)" stroke="var(--ink)" stroke-width="1.5"/>
    <line x1="8" y1="12" x2="47" y2="12" stroke="var(--ink-faint)" stroke-width="1"/>
    <line x1="8" y1="20" x2="42" y2="20" stroke="var(--ink-faint)" stroke-width="1"/>
    <line x1="8" y1="28" x2="45" y2="28" stroke="var(--ink-faint)" stroke-width="1"/>
    <text x="28" y="55" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="7" fill="var(--blue-pencil)">MEMORY.md</text>
  </g>

  <!-- Agent "eye" looking at above docs -->
  <g transform="translate(30, 50)">
    <path d="M0 12 Q15 0, 30 12 Q15 24, 0 12 Z" stroke="var(--blue-pencil)" stroke-width="2" fill="none"/>
    <circle cx="15" cy="12" r="5" fill="var(--blue-pencil)"/>
    <circle cx="16" cy="11" r="2" fill="var(--paper)"/>
  </g>
  <text x="65" y="48" font-family="Caveat, cursive" font-size="14" fill="var(--blue-pencil)" font-weight="600">agent sees these</text>

  <!-- Documents BELOW the cliff (falling / invisible) -->
  <!-- Runbook falling -->
  <g transform="translate(260, 200) rotate(25)">
    <rect width="45" height="55" rx="2" fill="var(--paper)" stroke="var(--ink-faint)" stroke-width="1" opacity="0.5"/>
    <line x1="6" y1="10" x2="38" y2="10" stroke="var(--ink-faint)" stroke-width="0.8" opacity="0.4"/>
    <line x1="6" y1="16" x2="34" y2="16" stroke="var(--ink-faint)" stroke-width="0.8" opacity="0.4"/>
    <text x="23" y="44" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="6" fill="var(--ink-faint)" opacity="0.6">RUNBOOK</text>
  </g>

  <!-- ADR falling -->
  <g transform="translate(300, 250) rotate(-15)">
    <rect width="40" height="50" rx="2" fill="var(--paper)" stroke="var(--ink-faint)" stroke-width="1" opacity="0.4"/>
    <line x1="5" y1="9" x2="34" y2="9" stroke="var(--ink-faint)" stroke-width="0.8" opacity="0.3"/>
    <text x="20" y="38" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="6" fill="var(--ink-faint)" opacity="0.5">ADR-016</text>
  </g>

  <!-- gotcha-log falling -->
  <g transform="translate(240, 270) rotate(40)">
    <rect width="42" height="52" rx="2" fill="var(--paper)" stroke="var(--ink-faint)" stroke-width="1" opacity="0.3"/>
    <text x="21" y="36" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="5.5" fill="var(--ink-faint)" opacity="0.4">gotcha-log</text>
  </g>

  <!-- "invisible" annotation -->
  <text x="320" y="195" font-family="Caveat, cursive" font-size="15" fill="var(--red-pencil)" font-weight="600" opacity="0.7">invisible!</text>

  <!-- The cliff label -->
  <path d="M190 160 L190 140" stroke="var(--red-pencil)" stroke-width="1.5" stroke-dasharray="4 3"/>
  <text x="192" y="135" font-family="Caveat, cursive" font-size="16" fill="var(--red-pencil)" font-weight="700">the cliff</text>

  <!-- Task-triggered pointer (the bridge) -->
  <g transform="translate(130, 120)">
    <path d="M0 40 L60 40 L80 55 L100 40" stroke="var(--green-pencil)" stroke-width="2.5" fill="none" stroke-linecap="round" stroke-dasharray="6 4"/>
    <text x="50" y="35" text-anchor="middle" font-family="Caveat, cursive" font-size="11" fill="var(--green-pencil)">"API returns 422 →"</text>
  </g>
</svg>
