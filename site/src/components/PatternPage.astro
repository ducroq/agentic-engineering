---
interface Props {
  number: string;
  title: string;
  subtitle: string;
  advisory?: boolean;
}
const { number, title, subtitle, advisory = false } = Astro.props;
const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : rawBase + '/';
---

<article class="pattern-page">
  <div class="pattern-header">
    <span class="pattern-number">Pattern {number}</span>
    {advisory && (
      <div class="advisory-banner">
        Advisory — this pattern addresses current model limitations that are improving. Useful now, may have a shelf life of 12-24 months.
      </div>
    )}
    <h1>{title}</h1>
    <p class="pattern-subtitle">{subtitle}</p>
  </div>
  <slot />
  <div class="pattern-nav">
    <a href={base}>&larr; Back to all patterns</a>
  </div>
</article>

<style>
  .pattern-page {
    max-width: 40rem;
    margin: 0 auto;
  }

  .pattern-header {
    padding: 2rem 0 1rem;
  }

  .pattern-number {
    font-size: 0.85rem;
    color: var(--evidence);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .advisory-banner {
    margin-top: 0.8rem;
    padding: 0.6rem 1rem;
    background: #fffbeb;
    border-left: 3px solid var(--caution);
    border-radius: 0 4px 4px 0;
    font-size: 0.85rem;
    color: var(--caution);
    font-weight: 500;
  }

  .pattern-header h1 {
    font-size: 2.2rem;
    line-height: 1.15;
    margin-top: 0.5rem;
  }

  .pattern-subtitle {
    font-size: 1rem;
    color: var(--text-secondary);
    margin-top: 0.5rem;
  }

  .pattern-page :global(.illustration-wrap) {
    margin: 2rem -1rem;
    display: flex;
    justify-content: center;
  }

  .pattern-page :global(.illustration-wrap .illustration) {
    width: 100%;
    max-width: 400px;
    height: auto;
  }

  .pattern-page :global(h2) {
    margin-top: 2.5rem;
    padding-top: 1rem;
    border-top: 1px solid var(--border);
  }

  .pattern-page :global(.evidence-box) {
    background: var(--surface-alt);
    border-left: 3px solid var(--evidence);
    border-radius: 0 4px 4px 0;
    padding: 1rem 1.2rem;
    margin: 1.2rem 0;
  }

  .pattern-page :global(.evidence-box p) {
    margin: 0;
    font-size: 0.9rem;
  }

  .pattern-page :global(.evidence-box strong) {
    color: var(--evidence);
  }

  .pattern-page :global(.monday-box) {
    background: var(--surface);
    border: 1px solid var(--action);
    border-left: 3px solid var(--action);
    border-radius: 0 4px 4px 0;
    padding: 1rem 1.2rem;
    margin: 1.5rem 0;
  }

  .pattern-page :global(.monday-box h3) {
    color: var(--action);
    margin-bottom: 0.3rem;
  }

  .pattern-page :global(.monday-box li) {
    font-size: 0.9rem;
    margin-top: 0.3rem;
  }

  .pattern-page :global(.caveat-box) {
    background: var(--surface-alt);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 1rem 1.2rem;
    margin: 1.5rem 0;
  }

  .pattern-page :global(.caveat-box h3) {
    color: var(--text-secondary);
  }

  .pattern-page :global(.caveat-box p),
  .pattern-page :global(.caveat-box li) {
    font-size: 0.88rem;
    color: var(--text-secondary);
  }

  .pattern-nav {
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
  }

  .pattern-nav a {
    font-size: 0.9rem;
    font-weight: 600;
  }
</style>
