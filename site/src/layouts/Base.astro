---
interface Props {
  title: string;
  description?: string;
}

const { title, description = "Durable tools and patterns for engineers working with AI agents." } = Astro.props;
const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : rawBase + '/';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  </head>
  <body>
    <nav class="site-nav">
      <a href={base} class="nav-home">
        <span>Augmented Engineering</span>
      </a>
      <div class="nav-links">
        <a href={`${base}#tools`}>Tools</a>
        <a href={`${base}#patterns`}>Patterns</a>
        <a href={`${base}#quick-ref`}>Quick Reference</a>
        <a href={`${base}#about`}>About</a>
      </div>
    </nav>
    <main>
      <slot />
    </main>
    <footer>
      <div class="footer-inner">
        <p>2025&ndash;2026</p>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  :root {
    --text: #1a1a1a;
    --text-secondary: #555;
    --text-muted: #888;
    --border: #e0e0e0;
    --surface: #ffffff;
    --surface-alt: #f7f7f7;
    --action: #16803c;
    --evidence: #1d6fa5;
    --caution: #b45309;
    --max-width: 54rem;

    /* Semantic colors for cards */
    --good-bg: #f0fdf4;
    --good-border: #bbf7d0;
    --good-text: #166534;
    --bad-bg: #fef2f2;
    --bad-border: #fecaca;
    --bad-text: #991b1b;
    --caution-bg: #fffbeb;
    --info-bg: #eff6ff;
    --info-border: #1d6fa5;

    /* Code blocks */
    --code-bg: #1a1a1a;
    --code-text: #e0e0e0;
  }

  @media (prefers-color-scheme: dark) {
    :root {
      --text: #e0e0e0;
      --text-secondary: #a0a0a0;
      --text-muted: #707070;
      --border: #333;
      --surface: #111111;
      --surface-alt: #1a1a1a;
      --action: #4ade80;
      --evidence: #60a5fa;
      --caution: #fbbf24;

      --good-bg: #052e16;
      --good-border: #166534;
      --good-text: #86efac;
      --bad-bg: #2a0a0a;
      --bad-border: #7f1d1d;
      --bad-text: #fca5a5;
      --caution-bg: #1c1508;
      --info-bg: #0c1a2e;
      --info-border: #60a5fa;

      --code-bg: #0a0a0a;
      --code-text: #d0d0d0;
    }
  }

  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  html {
    font-size: 17px;
    scroll-behavior: smooth;
  }

  body {
    font-family: 'Inter', system-ui, -apple-system, sans-serif;
    color: var(--text);
    background: var(--surface);
    line-height: 1.7;
    overflow-x: hidden;
  }

  main, nav, footer {
    position: relative;
  }

  .site-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 1.2rem 1.5rem;
    border-bottom: 1px solid var(--border);
  }

  .nav-home {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
    color: var(--text);
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: -0.01em;
  }

  .nav-links {
    display: flex;
    gap: 1.5rem;
  }

  .nav-links a {
    text-decoration: none;
    color: var(--text-secondary);
    font-size: 0.9rem;
    font-weight: 500;
    transition: color 0.15s;
  }

  .nav-links a:hover {
    color: var(--text);
  }

  main {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 1.5rem 4rem;
  }

  h1, h2, h3, h4 {
    font-family: 'Inter', system-ui, sans-serif;
    line-height: 1.2;
    color: var(--text);
    letter-spacing: -0.02em;
  }

  h1 { font-size: 2.4rem; font-weight: 700; }
  h2 { font-size: 1.6rem; font-weight: 700; margin-top: 2.5rem; }
  h3 { font-size: 1.15rem; font-weight: 600; }

  p {
    margin-top: 0.8rem;
  }

  a {
    color: var(--evidence);
    text-decoration: underline;
    text-underline-offset: 2px;
    text-decoration-thickness: 1px;
  }

  a:hover {
    text-decoration-thickness: 2px;
  }

  code {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.85em;
    background: var(--surface-alt);
    padding: 0.15em 0.4em;
    border-radius: 3px;
    border: 1px solid var(--border);
  }

  pre {
    background: var(--code-bg);
    color: var(--code-text);
    padding: 1.2rem 1.5rem;
    border-radius: 6px;
    overflow-x: auto;
    margin: 1.2rem 0;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.82rem;
    line-height: 1.6;
  }

  pre code {
    background: none;
    padding: 0;
    border: none;
  }

  footer {
    border-top: 1px solid var(--border);
    margin-top: 4rem;
  }

  .footer-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 1.5rem;
    text-align: center;
    color: var(--text-muted);
    font-size: 0.85rem;
  }

  @media (max-width: 640px) {
    html { font-size: 16px; }
    h1 { font-size: 2rem; }
    h2 { font-size: 1.4rem; }
    .site-nav { flex-direction: column; gap: 0.5rem; }
  }
</style>
